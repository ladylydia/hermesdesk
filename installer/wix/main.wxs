<?xml version="1.0" encoding="windows-1252"?>
<!--
  HermesDesk WiX template overriding Tauri's default.
  Tauri's bundler expands {{vars}} at build time.
  Per-user install under %LOCALAPPDATA%\HermesDesk; no UAC elevation.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  <Product
      Id="*"
      Name="{{product_name}}"
      UpgradeCode="{{upgrade_code}}"
      Language="!(loc.LANG)"
      Manufacturer="{{manufacturer}}"
      Version="{{version}}">
    <Package
        Id="*"
        Keywords="Installer"
        Description="{{long_description}}"
        Manufacturer="{{manufacturer}}"
        InstallerVersion="450"
        Languages="!(loc.LANG)"
        Compressed="yes"
        InstallScope="perUser"
        SummaryCodepage="!(loc.CODEPAGE)" />

    <MajorUpgrade
        Schedule="afterInstallInitialize"
        AllowDowngrades="no"
        AllowSameVersionUpgrades="yes"
        DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <Media Id="1" Cabinet="hermesdesk.cab" EmbedCab="yes" />

    <Property Id="ALLUSERS" Value="" />
    <Property Id="MSIINSTALLPERUSER" Value="1" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="INSTALLDIR" Name="HermesDesk">
          {{component_group_refs}}
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="HermesDesk" />
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="*">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="HermesDesk"
                  Description="Friendly AI helper for your PC"
                  Target="[INSTALLDIR]hermesdesk.exe"
                  WorkingDirectory="INSTALLDIR" />
        <RemoveFolder Id="CleanUpApplicationProgramsFolder"
                      Directory="ApplicationProgramsFolder"
                      On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\HermesDesk"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="MainFeature" Title="HermesDesk" Level="1">
      {{component_refs}}
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <Icon Id="hermesdesk.ico" SourceFile="{{icon_path}}" />
    <Property Id="ARPPRODUCTICON" Value="hermesdesk.ico" />
    <Property Id="ARPHELPLINK" Value="https://github.com/your-org/hermesdesk" />
    <Property Id="ARPNOMODIFY" Value="1" />
    <Property Id="ARPNOREPAIR" Value="1" />
  </Product>
</Wix>
