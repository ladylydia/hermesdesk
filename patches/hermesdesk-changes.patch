+    def _require_gateway_owner(self, source: SessionSource) -> Optional[str]:
+        """Return an error message if the caller is not a gateway owner.
+
+        When ``GATEWAY_OWNER_IDS`` is set (comma-separated user IDs), dangerous
+        slash commands (/restart, /model, /debug, etc.) require the caller to
+        be in that list.  When the env var is unset, all authorized users can
+        run these commands (backward-compatible).
+        """
+        _owner_ids_raw = os.getenv("GATEWAY_OWNER_IDS", "").strip()
+        if not _owner_ids_raw:
+            return None
+        _owner_ids = {uid.strip() for uid in _owner_ids_raw.split(",") if uid.strip()}
+        _caller = (source.user_id or "").strip()
+        if _caller in _owner_ids or _caller.split("@")[0] in _owner_ids:
+            return None
+        return (
+            "\u26d4 This command is restricted to gateway owners. "
+            "Ask the bot owner to add your user ID to GATEWAY_OWNER_IDS."
+        )
